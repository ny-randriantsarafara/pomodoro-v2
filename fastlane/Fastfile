require "shellwords"

default_platform(:ios)

def first_present_env(*names)
  names.each do |name|
    value = ENV[name].to_s.strip
    return value unless value.empty?
  end

  nil
end

def resolved_testflight_build_number
  first_present_env("IOS_BUILD_NUMBER", "GITHUB_RUN_NUMBER") || Time.now.utc.strftime("%Y%m%d%H%M%S")
end

def resolved_macos_build_number
  first_present_env("MACOS_BUILD_NUMBER", "GITHUB_RUN_NUMBER") || Time.now.utc.strftime("%Y%m%d%H%M%S")
end

def flutter_xcargs
  build_number = first_present_env("FLUTTER_BUILD_NUMBER")
  return nil unless build_number

  "FLUTTER_BUILD_NUMBER=#{build_number.shellescape}"
end

platform :ios do
  desc "Sync signing certificates and profiles via Match"
  lane :sync_signing do
    match(
      type: "appstore",
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: ENV["MATCH_APP_IDENTIFIER"] || "com.nyhasinavalona.rhythm",
      readonly: is_ci
    )
  end

  desc "Build iOS release IPA"
  lane :build_ios do
    setup_ci
    sync_signing

    build_options = {
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "Rhythm.ipa"
    }

    xcargs = flutter_xcargs
    build_options[:xcargs] = xcargs if xcargs

    build_app(**build_options)
  end

  desc "Build and upload to TestFlight"
  lane :testflight_upload do
    ENV["FLUTTER_BUILD_NUMBER"] = first_present_env("FLUTTER_BUILD_NUMBER") || resolved_testflight_build_number

    build_ios

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end

platform :mac do
  desc "Sync macOS signing certificates and profiles via Match"
  lane :sync_signing do
    match(
      type: "appstore",
      platform: "macos",
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: ENV["MATCH_APP_IDENTIFIER"] || "com.nyhasinavalona.rhythm",
      readonly: is_ci
    )
  end

  desc "Build macOS release app"
  lane :build_macos do
    setup_ci
    sync_signing

    build_options = {
      workspace: "macos/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/macos",
      output_name: "Rhythm.pkg"
    }

    xcargs = flutter_xcargs
    build_options[:xcargs] = xcargs if xcargs

    build_app(**build_options)
  end

  desc "Build and upload macOS to TestFlight"
  lane :testflight_upload do
    ENV["FLUTTER_BUILD_NUMBER"] = first_present_env("FLUTTER_BUILD_NUMBER") || resolved_macos_build_number

    build_macos

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
